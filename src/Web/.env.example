# Default Azure Entra App (Client) ID shown as the watermark on the pre-sign-in screen.
VITE_DEFAULT_CLIENT_ID=37cbb7e0-dc90-40cc-8386-874a39fe1c96

# Authority — "common" supports both Microsoft Accounts and any AAD tenant.
VITE_AUTHORITY=https://login.microsoftonline.com/common

# Backend API base URL (the .NET 10 project in D:\CMSPDemo\src\API).
VITE_API_BASE=http://localhost:5080
